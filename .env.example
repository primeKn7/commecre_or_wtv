# ============================================================
# AutoPark Manager – Configuration Supabase
# ============================================================
# Créez un projet sur https://supabase.com
# Puis copiez ces valeurs depuis :
#   Settings → API → Project URL
#   Settings → API → Project API keys → anon public
# ============================================================

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# ============================================================
# Paiement sandbox (choisissez un provider)
# ============================================================
VITE_STRIPE_PUBLIC_KEY=pk_test_votre_cle_stripe
VITE_PAYSTACK_PUBLIC_KEY=pk_test_votre_cle_paystack

# Mode de paiement actif : "stripe" | "paystack" | "simulation"
VITE_PAYMENT_PROVIDER=simulation

# ============================================================
# App
# ============================================================
VITE_APP_NAME=AutoPark Manager
VITE_APP_URL=http://localhost:5173
